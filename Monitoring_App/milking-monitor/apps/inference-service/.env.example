# Inference Service Environment Variables
# Copy this file to .env and fill in the values

# RTSP stream URL for camera feed
RTSP_STREAM_URL=rtsp://localhost:8554/stream

# Web app ingest endpoint and auth token
WEB_APP_INGEST_URL=http://localhost:3000/api/events/ingest
WEB_APP_INGEST_TOKEN=your-ingest-token-here

# YOLO model weights path (relative or absolute)
MODEL_WEIGHTS_PATH=Monitoring_App\milking-monitor\apps\inference-service\src\config\best.pt

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
